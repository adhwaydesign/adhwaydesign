function selectEmail(el, templateId) {
  document.querySelectorAll('.email-block').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  
  const template = templates[templateId];
  document.getElementById('email-subject').textContent = template.subject;
  document.getElementById('email-body').textContent = template.body;
  document.getElementById('email-compose').classList.add('show');
}

function personalize() {
  const body = document.getElementById('email-body').value || document.getElementById('email-body').textContent;
  const clientName = prompt('Client name:');
  const bizName = prompt('Business name:');
  const amount = prompt('Amount (if applicable):');
  const link = prompt('Preview/Live link (if applicable):');
  
  let updated = body
    .replace(/\[CLIENT NAME\]/g, clientName || '[CLIENT NAME]')
    .replace(/\[BUSINESS NAME\]/g, bizName || '[BUSINESS NAME]')
    .replace(/\[AMOUNT\]/g, amount || '[AMOUNT]')
    .replace(/\[PREVIEW LINK\]/g, link || '[PREVIEW LINK]')
    .replace(/\[YOUR LIVE URL\]/g, link || '[YOUR LIVE URL]')
    .replace(/\[YOUR ZELLE\]/g, document.getElementById('pr-zelle')?.value || '[YOUR ZELLE]')
    .replace(/\[YOUR PAYPAL\]/g, document.getElementById('pr-paypal')?.value || '[YOUR PAYPAL]');
  
  document.getElementById('email-body').textContent = updated;
  alert('Email personalized! Now copy and send.');
}

// ── COPY TO CLIPBOARD ──
function copyText(elementId) {
  const text = document.getElementById(elementId).textContent;
  navigator.clipboard.writeText(text).then(() => {
    const confirmEl = document.getElementById(elementId.replace('text','confirm') || elementId + '-confirm');
    if (confirmEl) { confirmEl.style.display='block'; setTimeout(() => { confirmEl.style.display='none'; }, 2000); }
  });
}

// ── GOOGLE SHEETS INTEGRATION ──
function loadClientsFromSheet() {
  const url = document.getElementById('sheet-url')?.value || localStorage.getItem('sheetUrl');
  if (!url) { alert('Please enter your Google Sheet URL in Help & Setup'); return; }
  
  alert('Sheet loading feature coming soon. For now, manually add clients in the "Client Tracker" tab.');
}

function testSheetConnection() {
  const url = document.getElementById('sheet-url').value;
  if (!url.includes('docs.google.com')) { alert('Invalid Google Sheets URL'); return; }
  localStorage.setItem('sheetUrl', url);
  document.getElementById('sheet-status').textContent = '✅ URL saved! (Full integration coming soon)';
}

function addClientManually() {
  const name = document.getElementById('manual-name').value;
  const biz = document.getElementById('manual-biz').value;
  const email = document.getElementById('manual-email').value;
  const pkg = document.getElementById('manual-package').value;
  const status = document.getElementById('manual-status').value;
  const date = document.getElementById('manual-date').value;

  if (!name || !biz || !email) { alert('Please fill in name, business, and email'); return; }

  const row = `<tr>
    <td>${name}</td>
    <td>${biz}</td>
    <td>${email}</td>
    <td>${pkg}</td>
    <td><span class="status-badge s-${status}">${status}</span></td>
    <td>${date}</td>
    <td><button class="btn btn-sm btn-ghost" onclick="this.closest('tr').remove()">Delete</button></td>
  </tr>`;

  const tbody = document.getElementById('clients-tbody');
  if (tbody.querySelector('tr:only-child')) tbody.innerHTML = '';
  tbody.innerHTML += row;

  document.getElementById('manual-name').value = '';
  document.getElementById('manual-biz').value = '';
  document.getElementById('manual-email').value = '';
  document.getElementById('manual-date').value = '';

  alert('Client added! (This is stored locally. Save to your Google Sheet to keep it permanently.)');
}

