<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>A.D.H.D — Admin Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700;900&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --green:#C8F500;--charcoal:#1A1A1A;--coral:#FF6B6B;
  --offwhite:#F7F6F0;--white:#FFFFFF;--gray:#F0F0EC;
  --mid:#2E2E2E;--textgray:#6B6B65;--border:#E2E2DE;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--offwhite);color:var(--charcoal);min-height:100vh}

/* ── LAYOUT ── */
.app{display:grid;grid-template-columns:240px 1fr;min-height:100vh}
.sidebar{background:var(--charcoal);padding:24px 0;position:sticky;top:0;height:100vh;overflow-y:auto;display:flex;flex-direction:column}
.sidebar-logo{padding:0 20px 24px;border-bottom:1px solid rgba(255,255,255,0.08)}
.logo-top{font-size:20px;font-weight:900;color:var(--green);letter-spacing:0.04em}
.logo-bot{font-size:9px;font-weight:300;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-top:3px}
.sidebar-section{padding:20px 0}
.sidebar-label{font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.25);padding:0 20px 8px}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 20px;font-size:13px;font-weight:500;color:rgba(255,255,255,0.5);cursor:pointer;transition:all 0.15s;border-left:2px solid transparent;user-select:none}
.nav-item:hover{color:var(--white);background:rgba(255,255,255,0.05)}
.nav-item.active{color:var(--green);background:rgba(200,245,0,0.07);border-left-color:var(--green)}
.nav-icon{font-size:16px;width:20px;text-align:center}
.sidebar-bottom{margin-top:auto;padding:16px 20px;border-top:1px solid rgba(255,255,255,0.08);font-size:11px;color:rgba(255,255,255,0.25);line-height:1.6}
.main{overflow-y:auto;padding:32px 36px}
.page{display:none}
.page.active{display:block;animation:fadeIn 0.3s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

/* ── TOPBAR ── */
.topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:32px}
.page-title{font-size:28px;font-weight:900;letter-spacing:-0.02em}
.page-title em{font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:var(--textgray)}
.topbar-right{display:flex;gap:12px;align-items:center}
.badge{font-size:11px;font-weight:600;padding:6px 14px;border-radius:100px;background:var(--gray);color:var(--textgray)}
.badge.live{background:#EAFFF0;color:#1A7A3C}

/* ── STATS ── */
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:32px}
.stat-box{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center}
.stat-box.highlight{background:var(--charcoal)}
.stat-num{font-size:32px;font-weight:900;color:var(--charcoal);line-height:1}
.stat-box.highlight .stat-num{color:var(--green)}
.stat-label{font-size:11px;color:var(--textgray);margin-top:6px;font-weight:500}
.stat-box.highlight .stat-label{color:rgba(255,255,255,0.5)}

/* ── PIPELINE ── */
.pipeline{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:32px}
.pipeline-col{background:var(--gray);border-radius:12px;padding:12px}
.pipeline-col-title{font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--textgray);margin-bottom:8px;display:flex;align-items:center;justify-content:space-between}
.pipeline-count{background:var(--charcoal);color:var(--white);width:20px;height:20px;border-radius:50%;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center}
.pipeline-card{background:var(--white);border-radius:8px;padding:10px;margin-bottom:6px;border:1px solid var(--border);font-size:12px;color:var(--charcoal);cursor:pointer;transition:all 0.15s}
.pipeline-card:hover{border-color:var(--charcoal);transform:translateY(-1px)}
.pipeline-card .name{font-weight:600;margin-bottom:2px}
.pipeline-card .biz{font-size:10px;color:var(--textgray)}

/* ── CARDS ── */
.card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:20px}
.card-title{font-size:13px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--textgray);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.card-title span{font-size:16px}

/* ── FORMS ── */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.form-grid.three{grid-template-columns:1fr 1fr 1fr}
.form-grid.full{grid-template-columns:1fr}
.field{display:flex;flex-direction:column;gap:5px}
.field.full{grid-column:1/-1}
label.lbl{font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--textgray)}
input,textarea,select{font-family:'DM Sans',sans-serif;font-size:14px;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;background:var(--white);color:var(--charcoal);outline:none;transition:border-color 0.2s;width:100%}
input:focus,textarea:focus,select:focus{border-color:var(--charcoal);box-shadow:0 0 0 3px rgba(26,26,26,0.05)}
textarea{resize:vertical;min-height:80px}

/* ── BUTTONS ── */
.btn{font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;padding:10px 20px;border-radius:100px;cursor:pointer;border:none;transition:all 0.15s;display:inline-flex;align-items:center;gap:7px;user-select:none}
.btn-primary{background:var(--charcoal);color:var(--green)}
.btn-primary:hover{background:var(--mid)}
.btn-green{background:var(--green);color:var(--charcoal);font-weight:700}
.btn-green:hover{background:#d4ff00;transform:translateY(-2px)}
.btn-ghost{background:transparent;color:var(--textgray);border:1.5px solid var(--border)}
.btn-ghost:hover{border-color:var(--charcoal);color:var(--charcoal)}
.btn-sm{padding:7px 14px;font-size:12px}
.btn:disabled{opacity:0.4;cursor:not-allowed}
.btn-row{display:flex;gap:12px;margin-top:16px;flex-wrap:wrap}

/* ── OUTPUT ── */
.output-box{background:var(--charcoal);border-radius:12px;padding:16px;margin-top:16px;display:none}
.output-box.show{display:block}
.output-label{font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:8px}
.output-text{font-family:'DM Sans',sans-serif;font-size:13px;color:rgba(255,255,255,0.85);line-height:1.7;white-space:pre-wrap;max-height:240px;overflow-y:auto}
.copy-btn{background:var(--green);color:var(--charcoal);font-weight:700;padding:8px 16px;border-radius:100px;border:none;cursor:pointer;font-size:12px;transition:all 0.2s;margin-top:8px}
.copy-btn:hover{background:#d4ff00;transform:translateY(-1px)}
.copy-confirm{font-size:12px;color:#1A7A3C;display:none;font-weight:500;margin-top:6px}

/* ── EMAIL TEMPLATES ── */
.email-block{background:var(--gray);border-radius:12px;padding:16px;margin-bottom:10px;border:1.5px solid transparent;cursor:pointer;transition:all 0.15s}
.email-block:hover,.email-block.selected{border-color:var(--charcoal);background:var(--white)}
.email-block-title{font-size:13px;font-weight:600;color:var(--charcoal);margin-bottom:4px}
.email-block-when{font-size:11px;color:var(--textgray)}
.email-preview{font-size:12px;color:var(--textgray);line-height:1.5;margin-top:8px;display:none}
.email-block.selected .email-preview{display:block}
.email-compose{background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:16px;margin-top:12px;display:none}
.email-compose.show{display:block}
.email-subject{font-size:12px;font-weight:600;color:var(--textgray);margin-bottom:3px}
.email-subject span{color:var(--charcoal)}
.email-body-text{font-size:13px;line-height:1.7;color:var(--charcoal);white-space:pre-wrap;background:var(--gray);border-radius:8px;padding:12px;margin:8px 0;font-family:'DM Sans',sans-serif;max-height:200px;overflow-y:auto}

/* ── TABLE ── */
.table-wrap{overflow-x:auto}
.data-table{width:100%;border-collapse:collapse}
.data-table th{font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--textgray);padding:10px 14px;text-align:left;border-bottom:2px solid var(--border)}
.data-table td{padding:12px 14px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:middle}
.data-table tr:hover td{background:#FAFAF8}
.status-badge{font-size:10px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;padding:3px 9px;border-radius:100px;display:inline-block}
.s-intake{background:#EAF3FF;color:#1A5A9E}
.s-payment{background:#FFF9EA;color:#9E7A1A}
.s-building{background:#F0EAFF;color:#5A1A9E}
.s-review{background:#FFE9E9;color:#9E1A1A}
.s-live{background:#EAFFF0;color:#1A7A3C}
.s-complete{background:var(--gray);color:var(--textgray)}

/* ── DIVIDER ── */
.divider{height:1px;background:var(--border);margin:20px 0}

/* ── TIP ── */
.tip{background:#FAFFF0;border-left:4px solid var(--green);border-radius:0 10px 10px 0;padding:12px 16px;font-size:13px;color:var(--charcoal);line-height:1.6;margin-bottom:16px}
.tip strong{font-weight:600}

/* ── UTIL ── */
.flex{display:flex;align-items:center;gap:8px}
.flex-between{display:flex;align-items:center;justify-content:space-between}
.empty-state{text-align:center;padding:40px 20px;color:var(--textgray)}
.empty-state .icon{font-size:40px;margin-bottom:12px}

@media(max-width:900px){
  .app{grid-template-columns:1fr}
  .sidebar{display:none}
  .stat-grid{grid-template-columns:repeat(2,1fr)}
  .pipeline{grid-template-columns:repeat(2,1fr)}
  .form-grid{grid-template-columns:1fr}
  .main{padding:20px}
}
</style>
</head>
<body>

<div class="app">

<!-- ══ SIDEBAR ══ -->
<div class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-top">A.D.H.D</div>
    <div class="logo-bot">A D Hway Design</div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Overview</div>
    <div class="nav-item active" onclick="goToPage('dashboard')"><span class="nav-icon">📊</span>Dashboard</div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Tools</div>
    <div class="nav-item" onclick="goToPage('clients')"><span class="nav-icon">👥</span>Client Tracker</div>
    <div class="nav-item" onclick="goToPage('payment')"><span class="nav-icon">💵</span>Payment Request</div>
    <div class="nav-item" onclick="goToPage('invoice')"><span class="nav-icon">🧾</span>Invoice Generator</div>
    <div class="nav-item" onclick="goToPage('emails')"><span class="nav-icon">✉️</span>Email Templates</div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Reference</div>
    <div class="nav-item" onclick="goToPage('help')"><span class="nav-icon">❓</span>Help & Setup</div>
  </div>

  <div class="sidebar-bottom">
    <strong>A.D.H.D</strong><br>
    Admin Dashboard<br><br>
    <span style="font-size:10px">Last updated: June 2026</span>
  </div>
</div>

<!-- ══ MAIN ══ -->
<div class="main">

<!-- ══ PAGE: DASHBOARD ══ -->
<div class="page active" id="page-dashboard">
  <div class="topbar">
    <h1 class="page-title">Dashboard</h1>
    <div class="topbar-right">
      <span class="badge live">🟢 Live</span>
    </div>
  </div>

  <div class="stat-grid">
    <div class="stat-box">
      <div class="stat-num" id="stat-intake">0</div>
      <div class="stat-label">Intake Received</div>
    </div>
    <div class="stat-box">
      <div class="stat-num" id="stat-payment">0</div>
      <div class="stat-label">Awaiting Payment</div>
    </div>
    <div class="stat-box">
      <div class="stat-num" id="stat-building">0</div>
      <div class="stat-label">Currently Building</div>
    </div>
    <div class="stat-box highlight">
      <div class="stat-num" id="stat-complete">0</div>
      <div class="stat-label">Completed</div>
    </div>
  </div>

  <div style="margin-bottom:24px">
    <h2 style="font-size:18px;font-weight:700;margin-bottom:12px">Project Pipeline</h2>
    <div class="pipeline">
      <div class="pipeline-col">
        <div class="pipeline-col-title">
          <span>Intake Received</span>
          <div class="pipeline-count" id="count-intake">0</div>
        </div>
        <div id="pipeline-intake"></div>
      </div>
      <div class="pipeline-col">
        <div class="pipeline-col-title">
          <span>Awaiting Payment</span>
          <div class="pipeline-count" id="count-payment">0</div>
        </div>
        <div id="pipeline-payment"></div>
      </div>
      <div class="pipeline-col">
        <div class="pipeline-col-title">
          <span>Building</span>
          <div class="pipeline-count" id="count-building">0</div>
        </div>
        <div id="pipeline-building"></div>
      </div>
      <div class="pipeline-col">
        <div class="pipeline-col-title">
          <span>Review</span>
          <div class="pipeline-count" id="count-review">0</div>
        </div>
        <div id="pipeline-review"></div>
      </div>
      <div class="pipeline-col">
        <div class="pipeline-col-title">
          <span>Complete</span>
          <div class="pipeline-count" id="count-complete">0</div>
        </div>
        <div id="pipeline-complete"></div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">📋 Quick Actions</div>
    <div class="flex" style="flex-wrap:wrap;gap:8px">
      <button class="btn btn-green" onclick="goToPage('payment')">Generate Payment Request</button>
      <button class="btn btn-green" onclick="goToPage('invoice')">Generate Invoice</button>
      <button class="btn btn-green" onclick="goToPage('emails')">View Email Templates</button>
      <button class="btn btn-ghost" onclick="goToPage('clients')">View All Clients</button>
    </div>
  </div>

  <div class="card">
    <div class="card-title">💡 Next Steps</div>
    <ol style="padding-left:20px;line-height:1.8;color:var(--charcoal)">
      <li><strong>Set up Google Sheets:</strong> Follow the "Help & Setup" tab to connect your client tracker</li>
      <li><strong>Customize payment details:</strong> Update Cash App, Zelle, PayPal info in "Payment Request" tool</li>
      <li><strong>Personalize email templates:</strong> Add your details to the template library</li>
      <li><strong>Generate first payment request:</strong> Use the tools to send to your first client</li>
    </ol>
  </div>
</div>

<!-- ══ PAGE: CLIENT TRACKER ══ -->
<div class="page" id="page-clients">
  <div class="topbar">
    <h1 class="page-title">Client <em>Tracker</em></h1>
    <button class="btn btn-ghost btn-sm" onclick="loadClientsFromSheet()">🔄 Refresh from Sheet</button>
  </div>

  <div class="tip">
    <strong>How it works:</strong> Your client data lives in a Google Sheet. Click "Refresh from Sheet" to load the latest clients here. <a href="#page-help" onclick="goToPage('help')" style="color:var(--charcoal);text-decoration:underline">See setup instructions →</a>
  </div>

  <div class="card">
    <div class="card-title">📊 All Clients</div>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Business</th>
            <th>Email</th>
            <th>Package</th>
            <th>Status</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="clients-tbody">
          <tr>
            <td colspan="7" style="text-align:center;padding:24px;color:var(--textgray)">
              <div class="empty-state" style="margin:0">
                <div class="icon">📭</div>
                <p>No clients yet. Fill out your Google Sheet and click "Refresh from Sheet" to load them here.</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-title">➕ Manually Add Client</div>
    <div class="form-grid full">
      <div class="field"><label class="lbl">Client Name</label><input id="manual-name" placeholder="e.g. Marcus Johnson" /></div>
      <div class="field"><label class="lbl">Business Name</label><input id="manual-biz" placeholder="e.g. East Side Auto" /></div>
      <div class="field"><label class="lbl">Email</label><input id="manual-email" placeholder="email@example.com" /></div>
      <div class="field"><label class="lbl">Package</label>
        <select id="manual-package">
          <option value="Starter ($99)">Starter ($99)</option>
          <option value="Standard ($149)">Standard ($149)</option>
          <option value="Starter + Logo ($149)">Starter + Logo ($149)</option>
          <option value="Standard + Logo ($199)">Standard + Logo ($199)</option>
          <option value="Custom">Custom</option>
        </select>
      </div>
      <div class="field"><label class="lbl">Status</label>
        <select id="manual-status">
          <option value="intake">Intake Received</option>
          <option value="payment">Awaiting Payment</option>
          <option value="building">Building</option>
          <option value="review">In Review</option>
          <option value="live">Live</option>
          <option value="complete">Complete</option>
        </select>
      </div>
      <div class="field"><label class="lbl">Date Added</label><input id="manual-date" type="date" value="" /></div>
    </div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="addClientManually()">Add Client</button>
    </div>
  </div>
</div>

<!-- ══ PAGE: PAYMENT REQUEST ══ -->
<div class="page" id="page-payment">
  <div class="topbar">
    <h1 class="page-title">Payment <em>Request</em></h1>
  </div>

  <div class="tip">
    <strong>How to use:</strong> Fill out the details, click "Generate payment request", then copy & send the message via text or email.
  </div>

  <div class="card">
    <div class="card-title">📋 Payment Details</div>
    <div class="form-grid">
      <div class="field"><label class="lbl">Client Name</label><input id="pr-name" placeholder="e.g. Marcus Johnson" /></div>
      <div class="field"><label class="lbl">Business Name</label><input id="pr-biz" placeholder="e.g. East Side Auto" /></div>
      <div class="field"><label class="lbl">Package</label>
        <select id="pr-pkg" onchange="updatePaymentAmounts()">
          <option value="Starter Website — $99">Starter Website — $99</option>
          <option value="Standard Website — $149">Standard Website — $149</option>
          <option value="Starter + Logo — $149">Starter + Logo — $149</option>
          <option value="Standard + Logo — $199">Standard + Logo — $199</option>
          <option value="Custom">Custom amount</option>
        </select>
      </div>
      <div class="field"><label class="lbl">Payment Type</label>
        <select id="pr-type" onchange="updatePaymentAmounts()">
          <option value="deposit">Deposit (50% to start)</option>
          <option value="final">Final payment (50% on completion)</option>
          <option value="full">Full payment upfront</option>
          <option value="hosting">Monthly hosting fee</option>
        </select>
      </div>
      <div class="field"><label class="lbl">Total Amount ($)</label><input id="pr-total" type="number" placeholder="99" oninput="updatePaymentAmounts()" /></div>
      <div class="field"><label class="lbl">Amount Due Now ($)</label><input id="pr-due" type="number" placeholder="49.50" readonly /></div>
      <div class="field full"><label class="lbl">Your Zelle (phone or email)</label><input id="pr-zelle" placeholder="hello@adhwaydesign.com" /></div>
      <div class="field full"><label class="lbl">Your PayPal (email)</label><input id="pr-paypal" placeholder="hello@adhwaydesign.com" /></div>
      <div class="field full"><label class="lbl">Custom note (optional)</label><input id="pr-note" placeholder="e.g. Please include your business name in the memo" /></div>
    </div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="generatePaymentRequest()">Generate payment request</button>
    </div>
  </div>

  <div class="output-box" id="pr-output">
    <div class="output-label">Payment Request Message — Copy & Send</div>
    <div class="output-text" id="pr-text"></div>
    <button class="copy-btn" onclick="copyText('pr-text')">📋 Copy Message</button>
    <div class="copy-confirm" id="pr-confirm">Copied!</div>
  </div>
</div>

<!-- ══ PAGE: INVOICE GENERATOR ══ -->
<div class="page" id="page-invoice">
  <div class="topbar">
    <h1 class="page-title">Invoice <em>Generator</em></h1>
  </div>

  <div class="tip">
    <strong>How to use:</strong> Fill out the invoice details and generate a professional receipt you can send to your client or save as PDF.
  </div>

  <div class="card">
    <div class="card-title">📋 Invoice Details</div>
    <div class="form-grid">
      <div class="field"><label class="lbl">Client Name</label><input id="inv-name" placeholder="e.g. Marcus Johnson" /></div>
      <div class="field"><label class="lbl">Business Name</label><input id="inv-biz" placeholder="e.g. East Side Auto" /></div>
      <div class="field"><label class="lbl">Email</label><input id="inv-email" placeholder="email@example.com" /></div>
      <div class="field"><label class="lbl">Invoice #</label><input id="inv-num" placeholder="e.g. INV-001" /></div>
      <div class="field"><label class="lbl">Invoice Date</label><input id="inv-date" type="date" value="" /></div>
      <div class="field full"><label class="lbl">Description</label><input id="inv-desc" placeholder="e.g. Website Design — Standard Package" /></div>
      <div class="field"><label class="lbl">Amount ($)</label><input id="inv-amount" type="number" placeholder="149" /></div>
      <div class="field"><label class="lbl">Payment Status</label>
        <select id="inv-status">
          <option value="Paid">Paid</option>
          <option value="Pending">Pending</option>
          <option value="Partial">Partially Paid</option>
        </select>
      </div>
