function goToPage(pageId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + pageId).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  event.target.closest('.nav-item')?.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}

// ── PAYMENT REQUEST ──
function updatePaymentAmounts() {
  const pkg = document.getElementById('pr-pkg').value;
  const type = document.getElementById('pr-type').value;
  const total = parseFloat(document.getElementById('pr-total').value) || 0;
  
  let amount = total;
  if (pkg.includes('99')) amount = 99;
  else if (pkg.includes('149')) amount = 149;
  else if (pkg.includes('199')) amount = 199;
  
  if (type === 'deposit') amount = amount * 0.5;
  else if (type === 'full') amount = amount;
  
  document.getElementById('pr-total').value = amount;
  document.getElementById('pr-due').value = amount.toFixed(2);
}

function generatePaymentRequest() {
  const name = document.getElementById('pr-name').value;
  const biz = document.getElementById('pr-biz').value;
  const pkg = document.getElementById('pr-pkg').value;
  const type = document.getElementById('pr-type').value;
  const due = document.getElementById('pr-due').value;
  const zelle = document.getElementById('pr-zelle').value;
  const paypal = document.getElementById('pr-paypal').value;
  const note = document.getElementById('pr-note').value;

  if (!name || !biz || !due) { alert('Please fill in name, business, and amount'); return; }

  const msg = `Hi ${name},

Thanks for choosing A.D.H.D | A D Hway Design! I'm ready to build your website for ${biz}.

Here's your payment request to get started:
• Amount due: $${due}
• Package: ${pkg}
• Payment method: Zelle or PayPal (your choice)

PAYMENT METHODS:
Zelle: ${zelle}
PayPal: ${paypal}

${note ? 'Note: ' + note : ''}

Once I receive payment, I'll start building your custom website. You'll get a preview within 48–72 hours of receiving all your content.

Questions? Reply to this message or email hello@adhwaydesign.com.

Thanks,
Destiny Holloway
A.D.H.D | A D Hway Design
Cleveland, OH`;

  document.getElementById('pr-text').textContent = msg;
  document.getElementById('pr-output').classList.add('show');
}

